.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.merchant-list {
  padding: 16rpx 0;
}

.merchant-card {
  background-color: #fff;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.merchant-content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.merchant-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.merchant-info {
  flex: 1;
  overflow: hidden;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.merchant-rating {
  font-size: 24rpx;
  color: #FF9800;
  display: block;
  margin-bottom: 6rpx;
}

.merchant-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-btn {
  text-align: right;
  font-size: 24rpx;
  color: #FF4D4F;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}
