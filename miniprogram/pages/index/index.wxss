.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 定位栏 */
.location-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #2AAE67;
}

.location-info {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
  max-width: 320rpx;
}

.loc-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.loc-text {
  font-size: 26rpx;
  color: #fff;
  margin: 0 8rpx;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.loc-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.search-entry {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
}

.search-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.search-placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 340rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 公告 */
.announcement-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 24rpx;
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.announcement-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.announcement-swiper {
  flex: 1;
  height: 40rpx;
}

.announcement-text {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* 分类 */
.category-section {
  background-color: #fff;
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.category-grid {
  display: flex;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.category-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-icon {
  font-size: 56rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

/* 排序筛选栏 */
.sort-filter-bar {
  background-color: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 12rpx;
  padding: 0 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.sort-tabs {
  display: flex;
  align-items: center;
  height: 80rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.sort-tab {
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  height: 80rpx;
  line-height: 80rpx;
  position: relative;
}

.sort-tab.active {
  color: #2AAE67;
  font-weight: bold;
}

.sort-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #2AAE67;
  border-radius: 2rpx;
}

/* 商家卡片 */
.merchant-list {
  padding: 0 0 16rpx;
}

.merchant-card {
  display: flex;
  background-color: #fff;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.merchant-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.merchant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.merchant-name-row {
  margin-bottom: 8rpx;
}

.merchant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.merchant-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.merchant-rating {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: bold;
  margin-right: 16rpx;
}

.merchant-sales {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

.merchant-time {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

.merchant-distance {
  font-size: 22rpx;
  color: #2AAE67;
  font-weight: bold;
}

.merchant-tags {
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.tag-free {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: bold;
  margin-right: 12rpx;
}

.tag-fee {
  font-size: 22rpx;
  color: #999;
  margin-right: 12rpx;
}

.tag-range {
  font-size: 20rpx;
  color: #fff;
  background-color: #2AAE67;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.merchant-desc {
  font-size: 24rpx;
  color: #2AAE67;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
