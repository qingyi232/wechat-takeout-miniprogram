.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.info-card {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #333;
}

.info-right {
  display: flex;
  align-items: center;
}

.info-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.info-value {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.info-arrow {
  font-size: 28rpx;
  color: #ccc;
}
