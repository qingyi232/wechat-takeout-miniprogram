.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #2AAE67;
  font-weight: bold;
  flex-shrink: 0;
}

.category-filter {
  background-color: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
}

.filter-tag {
  padding: 12rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.search-results {
  padding: 8rpx 0;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.merchant-card {
  display: flex;
  background-color: #fff;
  margin: 12rpx 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.merchant-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.merchant-info {
  flex: 1;
  overflow: hidden;
}

.merchant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.merchant-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.merchant-rating {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: bold;
  margin-right: 16rpx;
}

.merchant-sales,
.merchant-time {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

.merchant-tags {
  margin-bottom: 6rpx;
}

.tag-free {
  font-size: 22rpx;
  color: #52C41A;
  font-weight: bold;
}

.merchant-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
