.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.address-list {
  padding: 16rpx 0;
}

.address-item {
  background-color: #fff;
  margin: 12rpx 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.address-info {
  margin-bottom: 16rpx;
}

.address-main {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.address-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.default-tag {
  font-size: 20rpx;
  color: #2AAE67;
  border: 1rpx solid #2AAE67;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.address-contact {
  font-size: 26rpx;
  color: #666;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}

.action-edit, .action-delete {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  margin-left: 16rpx;
  border-radius: 20rpx;
}

.action-edit {
  color: #2AAE67;
  border: 1rpx solid #2AAE67;
}

.action-delete {
  color: #FF4D4F;
  border: 1rpx solid #FF4D4F;
}

.add-btn-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background-color: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}

.add-btn {
  background-color: #2AAE67;
  color: #333;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}
