.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.status-bar {
  padding: 32rpx 24rpx;
  color: #fff;
}

.status-bar.status-pending_pay { background-color: #FF9800; }
.status-bar.status-pending_accept { background-color: #2196F3; }
.status-bar.status-delivering { background-color: #52C41A; }
.status-bar.status-completed { background-color: #9E9E9E; }
.status-bar.status-cancelled { background-color: #9E9E9E; }
.status-bar.status-refunded { background-color: #FF4D4F; }

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.section-card {
  background-color: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.address-info {
  padding: 8rpx 0;
}

.address-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.address-contact {
  font-size: 26rpx;
  color: #666;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.goods-qty {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.goods-price {
  font-size: 28rpx;
  flex-shrink: 0;
}

.order-summary {
  padding-top: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #666;
}

.summary-row.total {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.discount-value {
  color: #FF9800;
}

.total-value {
  color: #FF5F3E;
  font-size: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.action-btn {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.action-btn.pay {
  background-color: #2AAE67;
  color: #333;
  font-weight: bold;
}

.action-btn.cancel {
  border: 1rpx solid #FF4D4F;
  color: #FF4D4F;
}

.action-btn.confirm {
  background-color: #52C41A;
  color: #fff;
}
