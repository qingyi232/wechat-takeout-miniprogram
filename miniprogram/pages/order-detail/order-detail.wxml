<view class="container" wx:if="{{order}}">
  <!-- 订单状态 -->
  <view class="status-bar status-{{order.status}}">
    <text class="status-text">{{order.statusText}}</text>
    <text class="status-desc" wx:if="{{order.status === 'delivering'}}">骑手正在配送中，请耐心等待</text>
    <text class="status-desc" wx:elif="{{order.status === 'pending_accept'}}">商家正在备餐，请耐心等待</text>
    <text class="status-desc" wx:elif="{{order.status === 'pending_pay'}}">请尽快完成支付</text>
  </view>

  <!-- 收货地址 -->
  <view class="section-card" wx:if="{{order.address}}">
    <view class="section-title">收货信息</view>
    <view class="address-info">
      <text class="address-text">{{order.address.address}}</text>
      <text class="address-contact">{{order.address.name}}  {{order.address.phone}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="section-card">
    <view class="section-title">{{order.merchantName}}</view>
    <view class="goods-item" wx:for="{{order.items}}" wx:key="id">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-qty">x {{item.quantity}}</text>
      </view>
      <text class="goods-price price">¥{{item.price}}</text>
    </view>
    <view class="order-summary">
      <view class="summary-row" wx:if="{{order.discount > 0}}">
        <text>已优惠</text>
        <text class="discount-value">-¥{{order.discount}}</text>
      </view>
      <view class="summary-row" wx:if="{{order.deliveryFee > 0}}">
        <text>配送费</text>
        <text class="delivery-fee-value">¥{{order.deliveryFee}}</text>
      </view>
      <view class="summary-row" wx:if="{{order.deliveryFee == 0}}">
        <text>配送费</text>
        <text class="delivery-fee-value" style="color:#2AAE67">免配送费</text>
      </view>
      <view class="summary-row total">
        <text>实付</text>
        <text class="total-value">¥{{order.totalPrice}}</text>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="section-card">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value" bindtap="copyOrderId">{{order.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text class="info-label">支付时间</text>
      <text class="info-value">{{order.payTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions" wx:if="{{order.status === 'pending_pay' || order.status === 'delivering'}}">
    <view wx:if="{{order.status === 'pending_pay'}}" class="action-btn pay" bindtap="payOrder">支付</view>
    <view wx:if="{{order.status === 'pending_pay'}}" class="action-btn cancel" bindtap="cancelOrder">取消订单</view>
    <view wx:if="{{order.status === 'delivering'}}" class="action-btn confirm" bindtap="confirmReceive">确认收货</view>
  </view>
</view>
