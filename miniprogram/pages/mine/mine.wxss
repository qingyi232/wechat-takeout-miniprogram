.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 用户头部 */
.user-header {
  background: linear-gradient(180deg, #2AAE67 0%, #5DC98A 100%);
  padding: 40rpx 32rpx 60rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  background-color: #eee;
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ddd;
}

.default-avatar-icon {
  font-size: 60rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-account {
  font-size: 24rpx;
  color: #666;
}

/* 功能区 */
.function-card {
  background-color: #fff;
  margin: -20rpx 24rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
}

.function-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.function-grid {
  display: flex;
  justify-content: space-around;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.function-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.function-name {
  font-size: 24rpx;
  color: #333;
}

/* 设置列表 */
.settings-card {
  background-color: #fff;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.settings-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.settings-arrow {
  font-size: 28rpx;
  color: #ccc;
}
