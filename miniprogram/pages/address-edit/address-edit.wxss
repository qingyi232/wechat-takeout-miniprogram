.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.form-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.switch-item {
  justify-content: space-between;
}

.save-btn {
  background-color: #2AAE67;
  color: #333;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.address-pick {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 40rpx;
}

.address-picked {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.address-placeholder {
  font-size: 28rpx;
  color: #999;
  flex: 1;
}

.loc-icon {
  font-size: 32rpx;
  margin-left: 8rpx;
}
