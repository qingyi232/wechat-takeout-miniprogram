<view class="container">
  <view wx:if="{{historyList.length === 0}}" class="empty-tip">
    <text class="empty-icon">🕐</text>
    <text>暂无浏览记录</text>
  </view>

  <view class="history-header" wx:if="{{historyList.length > 0}}">
    <text class="history-count">共{{historyList.length}}条记录</text>
    <text class="clear-btn" bindtap="clearHistory">清空记录</text>
  </view>

  <view class="merchant-list">
    <view class="merchant-card" wx:for="{{historyList}}" wx:key="id" bindtap="goShop" data-id="{{item.id}}">
      <image class="merchant-logo" src="{{item.logo}}" mode="aspectFill"></image>
      <view class="merchant-info">
        <text class="merchant-name">{{item.name}}</text>
        <text class="merchant-rating">{{item.rating}}分</text>
        <text class="merchant-desc">{{item.description}}</text>
      </view>
      <text class="browse-time">{{item.timeText}}</text>
    </view>
  </view>
</view>
