.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
}

.history-count {
  font-size: 24rpx;
  color: #999;
}

.clear-btn {
  font-size: 24rpx;
  color: #FF4D4F;
}

.merchant-list {
  padding: 0 0 16rpx;
}

.merchant-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  margin: 8rpx 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.merchant-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.merchant-info {
  flex: 1;
  overflow: hidden;
}

.merchant-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.merchant-rating {
  font-size: 22rpx;
  color: #FF9800;
  display: block;
  margin-bottom: 4rpx;
}

.merchant-desc {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.browse-time {
  font-size: 22rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 12rpx;
}
