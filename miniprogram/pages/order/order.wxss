.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 状态标签 */
.status-tabs {
  display: flex;
  background-color: #fff;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.status-tab.active {
  color: #333;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #2AAE67;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 16rpx 0;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-merchant-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 24rpx;
  font-weight: bold;
}

.order-status.pending_pay {
  color: #FF9800;
}

.order-status.pending_accept {
  color: #2AAE67;
}

.order-status.delivering {
  color: #52C41A;
}

.order-status.completed {
  color: #999;
}

.order-status.cancelled {
  color: #999;
}

.order-status.refunded {
  color: #FF4D4F;
}

/* 订单内容 */
.order-content {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
}

.order-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-price-row {
  display: flex;
  align-items: baseline;
}

.order-price-label {
  font-size: 24rpx;
  color: #333;
}

.order-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF5F3E;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-action-left {
  display: flex;
  align-items: center;
}

.order-action-right {
  display: flex;
  align-items: center;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
  border: 1rpx solid #ddd;
  color: #666;
}

.action-btn.pay {
  border-color: #2AAE67;
  background-color: #2AAE67;
  color: #333;
  font-weight: bold;
}

.action-btn.cancel {
  border-color: #FF4D4F;
  color: #FF4D4F;
}

.action-btn.refund {
  border-color: #FF9800;
  color: #FF9800;
}

.action-btn.confirm {
  border-color: #52C41A;
  color: #52C41A;
}

.action-btn.comment {
  border-color: #2AAE67;
  color: #2AAE67;
}

.action-btn.delete {
  border: none;
  color: #999;
  font-size: 24rpx;
  padding-left: 0;
  margin-left: 0;
}
