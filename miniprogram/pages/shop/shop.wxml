<view class="container">
  <!-- 商家信息 -->
  <view class="merchant-header">
    <view class="merchant-info-left">
      <view class="merchant-name-row">
        <text class="merchant-name">{{merchant.name}}</text>
        <text class="star-icon" bindtap="toggleFavorite">{{isFavorite ? '★' : '☆'}}</text>
      </view>
      <view class="merchant-tags-row">
        <text class="info-tag">平台配送</text>
        <text class="info-divider">|</text>
        <text class="info-tag">{{merchant.freeDelivery ? '免配送费' : '配送费¥' + merchant.deliveryFee}}</text>
        <text class="info-divider">|</text>
        <text class="info-tag">{{merchant.deliveryTime}}分钟内送达</text>
      </view>
      <view class="merchant-address">
        <text>地址：{{merchant.address}}</text>
      </view>
      <view class="merchant-phone">
        <text>联系电话：{{merchant.phone}}</text>
      </view>
    </view>
    <image class="merchant-logo" src="{{merchant.logo}}" mode="aspectFill"></image>
  </view>

  <!-- 全部商品/评价 切换 -->
  <view class="tab-switch">
    <view class="tab-item {{currentTab === 'goods' ? 'active' : ''}}" bindtap="switchTab" data-tab="goods">
      <text>全部商品</text>
    </view>
    <view class="tab-item {{currentTab === 'comment' ? 'active' : ''}}" bindtap="switchTab" data-tab="comment">
      <text>评价</text>
    </view>
  </view>

  <!-- 商品区域 -->
  <view class="goods-area" wx:if="{{currentTab === 'goods'}}">
    <!-- 左侧分类 -->
    <scroll-view class="category-sidebar" scroll-y="{{true}}" scroll-into-view="{{scrollCategoryId}}">
      <view class="category-item {{activeCategoryId === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
        <text class="category-text">{{item.name}}</text>
      </view>
      <view wx:if="{{combos.length > 0}}" class="category-item {{activeCategoryId === 'combo' ? 'active' : ''}}" bindtap="selectCategory" data-id="combo">
        <text class="category-text">优惠套餐</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view class="dish-list" scroll-y="{{true}}" scroll-into-view="{{scrollDishId}}" wx:if="{{!showCombo}}">
      <view class="dish-item" wx:for="{{filteredDishes}}" wx:key="id">
        <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.description}}</text>
          <view class="dish-discount-row">
            <text class="tag tag-discount" wx:if="{{item.discount < 1}}">{{item.discount * 10}}折</text>
            <text class="dish-sales">已售{{item.sales}}</text>
            <text class="dish-stock" wx:if="{{item.stock <= 20}}">仅剩{{item.stock}}份</text>
          </view>
          <view class="dish-price-row">
            <text class="original-price">¥{{item.originalPrice}}</text>
            <text class="current-price">¥{{item.currentPrice}}</text>
            <text class="tag tag-price">到手价</text>
          </view>
          <view class="dish-buy-btn" bindtap="addToCart" data-dish="{{item}}">
            <text>选购</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 套餐列表 -->
    <scroll-view class="dish-list" scroll-y="{{true}}" wx:if="{{showCombo}}">
      <view wx:if="{{combos.length === 0}}" class="empty-tip"><text>暂无套餐</text></view>
      <view class="dish-item" wx:for="{{combos}}" wx:key="id">
        <image class="dish-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.description}}</text>
          <view class="dish-discount-row">
            <text class="tag tag-discount">套餐优惠</text>
          </view>
          <view class="dish-price-row">
            <text class="current-price">¥{{item.currentPrice}}</text>
          </view>
          <view class="dish-buy-btn" bindtap="addComboToCart" data-combo="{{item}}">
            <text>选购</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 评价区域 -->
  <view class="comment-area" wx:if="{{currentTab === 'comment'}}">
    <view wx:if="{{comments.length === 0}}" class="empty-tip">
      <text>暂无评价</text>
    </view>
    <view class="comment-item" wx:for="{{comments}}" wx:key="index">
      <view class="comment-user">
        <image class="comment-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
        <text class="comment-nickname">{{item.nickname}}</text>
        <text class="comment-time">{{item.time}}</text>
      </view>
      <view class="comment-rating">
        <text class="comment-stars">{{item.stars}}</text>
      </view>
      <text class="comment-content">{{item.content}}</text>
    </view>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar">
    <view class="cart-icon-wrapper" bindtap="toggleCartPopup">
      <text class="cart-icon-text">🛒</text>
      <text class="cart-label">购物车</text>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="cart-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="goConfirm">
      <text>立即下单</text>
    </view>
  </view>

  <!-- 规格选择弹窗 -->
  <view class="spec-mask" wx:if="{{showSpecPopup}}" bindtap="closeSpecPopup"></view>
  <view class="spec-popup {{showSpecPopup ? 'show' : ''}}">
    <view class="spec-header">
      <image class="spec-dish-image" src="{{specDish.image}}" mode="aspectFill"></image>
      <view class="spec-dish-info">
        <text class="spec-dish-name">{{specDish.name}}</text>
        <text class="spec-dish-price">¥{{specPrice}}</text>
      </view>
      <view class="spec-close" bindtap="closeSpecPopup">✕</view>
    </view>
    <scroll-view class="spec-body" scroll-y="{{true}}">
      <view class="spec-group" wx:for="{{specGroups}}" wx:key="id">
        <view class="spec-group-title">
          <text>{{item.groupName}}</text>
          <text class="spec-required" wx:if="{{item.required}}">（必选）</text>
        </view>
        <view class="spec-options">
          <view class="spec-option {{selectedSpecs[item.id].id === spec.id ? 'active' : ''}}" wx:for="{{item.specs}}" wx:for-item="spec" wx:key="id" bindtap="selectSpec" data-group-id="{{item.id}}" data-spec-id="{{spec.id}}">
            <text>{{spec.name}}</text>
            <text class="spec-extra" wx:if="{{spec.priceAdjustment > 0}}">+¥{{spec.priceAdjustment}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="spec-footer">
      <view class="spec-confirm-btn" bindtap="confirmSpec">
        <text>加入购物车 ¥{{specPrice}}</text>
      </view>
    </view>
  </view>

  <!-- 购物车弹窗 -->
  <view class="cart-mask" wx:if="{{showCartPopup}}" bindtap="toggleCartPopup"></view>
  <view class="cart-popup {{showCartPopup ? 'show' : ''}}">
    <view class="cart-popup-header">
      <view></view>
      <view class="cart-clear" bindtap="clearCart">
        <text>🗑 清空</text>
      </view>
    </view>
    <scroll-view class="cart-popup-list" scroll-y="{{true}}">
      <view class="cart-popup-item" wx:for="{{cartItems}}" wx:key="id">
        <image class="cart-item-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-price price">¥{{item.currentPrice}}</text>
        </view>
        <view class="cart-item-controls">
          <view class="qty-btn minus" bindtap="decreaseQty" data-id="{{item.id}}" data-type="{{item.type || 'dish'}}" data-speckey="{{item.specKey || ''}}">
            <text>-</text>
          </view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn plus" bindtap="increaseQty" data-id="{{item.id}}" data-type="{{item.type || 'dish'}}" data-speckey="{{item.specKey || ''}}">
            <text>+</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="cart-popup-total" wx:if="{{cartItems.length > 0}}">
      <text>总金额：</text>
      <text class="price">¥ {{cartTotal}}</text>
    </view>
  </view>
</view>
