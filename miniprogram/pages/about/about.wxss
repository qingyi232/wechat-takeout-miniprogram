.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: linear-gradient(180deg, #2AAE67 0%, #5DC98A 100%);
}

.app-logo {
  font-size: 100rpx;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 24rpx;
  color: #666;
}

.info-card {
  background-color: #fff;
  margin: 24rpx;
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.desc-card {
  background-color: #fff;
  margin: 0 24rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.desc-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}
