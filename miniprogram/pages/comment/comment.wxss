.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.comment-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 32rpx;
}

.rating-section {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 24rpx;
}

.stars {
  display: flex;
}

.star {
  font-size: 48rpx;
  color: #ddd;
  margin-right: 8rpx;
}

.star.active {
  color: #2AAE67;
}

.tag-section {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.comment-tag {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.comment-tag.selected {
  background-color: #FFF8E1;
  color: #2AAE67;
  border-color: #2AAE67;
}

.textarea-section {
  position: relative;
}

.comment-textarea {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.submit-btn {
  background-color: #2AAE67;
  color: #333;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}
